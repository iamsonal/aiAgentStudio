<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>63.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Markdown Viewer</masterLabel>
    <description>Renders markdown text as formatted HTML. Supports GFM (GitHub Flavored Markdown).</description>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage,lightning__AppPage,lightning__HomePage">
            <property name="value" type="String" label="Markdown Content" description="The markdown text to render"/>
            <property name="hideLoading" type="Boolean" label="Hide Loading Skeleton" default="false" description="Hide the loading skeleton animation"/>
        </targetConfig>
        <targetConfig targets="lightning__FlowScreen">
            <property name="value" type="String" label="Markdown Content" description="The markdown text to render" role="inputOnly"/>
            <property name="hideLoading" type="Boolean" label="Hide Loading Skeleton" default="false" description="Hide the loading skeleton animation"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
