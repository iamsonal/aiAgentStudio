<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>HITLMode__c</fullName>
    <description>Human-in-the-loop mode that determines whether this capability needs confirmation or approval before it runs.</description>
    <externalId>false</externalId>
    <inlineHelpText>Leave blank to run immediately. Use Confirmation for inline confirmation, Approval for formal approval, Confirmation Then Approval for both, or Conditional Approval to let the model decide based on context.</inlineHelpText>
    <label>HITL Mode</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Confirmation</fullName>
                <default>false</default>
                <label>Confirmation</label>
            </value>
            <value>
                <fullName>Approval</fullName>
                <default>false</default>
                <label>Approval</label>
            </value>
            <value>
                <fullName>ConfirmationThenApproval</fullName>
                <default>false</default>
                <label>Confirmation Then Approval</label>
            </value>
            <value>
                <fullName>ConditionalApproval</fullName>
                <default>false</default>
                <label>Conditional Approval (LLM Decides)</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
