<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>HITLNotificationPreference__c</fullName>
    <description>Controls when users are notified about human-in-the-loop approval outcomes for this capability.</description>
    <externalId>false</externalId>
    <inlineHelpText>Choose when to notify users about approval outcomes. This applies to Approval and Confirmation Then Approval modes only. Leave blank to send no notifications.</inlineHelpText>
    <label>HITL Notification Preference</label>
    <required>false</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Always Notify</fullName>
                <default>true</default>
                <label>Always Notify</label>
            </value>
            <value>
                <fullName>Notify on Rejection Only</fullName>
                <default>false</default>
                <label>Notify on Rejection Only</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>