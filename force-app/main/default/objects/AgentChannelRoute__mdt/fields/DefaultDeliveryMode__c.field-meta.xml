<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>DefaultDeliveryMode__c</fullName>
    <description>Default completion and reply behavior to apply when this route matches an inbound interaction.</description>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>Choose how replies should be handled for this route. Auto Reply sends automatically when the endpoint allows it; the other options require review, routing only, or handoff.</inlineHelpText>
    <label>Default Delivery Mode</label>
    <required>false</required>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Auto Reply</fullName>
                <default>true</default>
                <label>Auto Reply</label>
            </value>
            <value>
                <fullName>Review Before Send</fullName>
                <default>false</default>
                <label>Review Before Send</label>
            </value>
            <value>
                <fullName>Route Only</fullName>
                <default>false</default>
                <label>Route Only</label>
            </value>
            <value>
                <fullName>Human Handoff</fullName>
                <default>false</default>
                <label>Human Handoff</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
