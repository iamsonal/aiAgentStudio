<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>CompletionMode__c</fullName>
    <description>Effective delivery mode applied to this execution after routing, channel policy, and agent defaults are resolved.</description>
    <inlineHelpText>Shows how this execution is expected to finish on its channel, such as auto reply, review before send, route only, or human handoff.</inlineHelpText>
    <label>Completion Mode</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Auto Reply</fullName>
                <default>true</default>
                <label>Auto Reply</label>
            </value>
            <value>
                <fullName>Review Before Send</fullName>
                <default>false</default>
                <label>Review Before Send</label>
            </value>
            <value>
                <fullName>Route Only</fullName>
                <default>false</default>
                <label>Route Only</label>
            </value>
            <value>
                <fullName>Human Handoff</fullName>
                <default>false</default>
                <label>Human Handoff</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
