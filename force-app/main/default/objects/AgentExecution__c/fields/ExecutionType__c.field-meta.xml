<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ExecutionType__c</fullName>
    <description>Defines the resolved execution mode for this run. Conversational and Direct are agent runtime modes, while Pipeline represents a composition workflow run.</description>
    <inlineHelpText>Shows how this execution is being processed. Pipeline runs belong to the composition subsystem rather than the normal agent runtime registry.</inlineHelpText>
    <label>Execution Mode</label>
    <required>true</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Conversational</fullName>
                <default>true</default>
                <label>Conversational</label>
            </value>
            <value>
                <fullName>Direct</fullName>
                <default>false</default>
                <label>Direct</label>
            </value>
            <value>
                <fullName>Pipeline</fullName>
                <default>false</default>
                <label>Pipeline</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
