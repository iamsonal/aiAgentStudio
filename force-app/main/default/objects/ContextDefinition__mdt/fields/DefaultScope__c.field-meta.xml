<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>DefaultScope__c</fullName>
    <description>Authoritative anchor scope the framework should use when resolving this context definition.</description>
    <fieldManageability>DeveloperControlled</fieldManageability>
    <inlineHelpText>Choose where this definition should look for its anchor. Record uses the current record, User uses the current user, Session uses the interaction session, and Global runs without an anchor.</inlineHelpText>
    <label>Default Scope</label>
    <required>true</required>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value><fullName>Record</fullName><default>true</default><label>Record</label></value>
            <value><fullName>User</fullName><default>false</default><label>User</label></value>
            <value><fullName>Session</fullName><default>false</default><label>Session</label></value>
            <value><fullName>Global</fullName><default>false</default><label>Global</label></value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
