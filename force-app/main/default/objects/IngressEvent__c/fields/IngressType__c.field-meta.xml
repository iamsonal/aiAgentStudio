<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>IngressType__c</fullName>
    <description>High-level category describing how this inbound event entered Salesforce.</description>
    <inlineHelpText>Use this to distinguish normalized API submissions, platform-native records, internal platform events, and raw webhook traffic.</inlineHelpText>
    <label>Ingress Type</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value><fullName>NormalizedApi</fullName><default>false</default><label>Normalized API</label></value>
            <value><fullName>PlatformRecord</fullName><default>false</default><label>Platform Record</label></value>
            <value><fullName>InternalEvent</fullName><default>false</default><label>Internal Event</label></value>
            <value><fullName>Webhook</fullName><default>true</default><label>Webhook</label></value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
