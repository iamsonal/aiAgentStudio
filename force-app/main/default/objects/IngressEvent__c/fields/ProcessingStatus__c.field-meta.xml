<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ProcessingStatus__c</fullName>
    <description>Current lifecycle state for internal handling of this ingress event.</description>
    <inlineHelpText>Track whether the event has only been received, is ready or processing, was suppressed as a duplicate, or completed with success or failure.</inlineHelpText>
    <label>Processing Status</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value><fullName>Received</fullName><default>true</default><label>Received</label></value>
            <value><fullName>Verified</fullName><default>false</default><label>Verified</label></value>
            <value><fullName>Duplicate</fullName><default>false</default><label>Duplicate</label></value>
            <value><fullName>Ready</fullName><default>false</default><label>Ready</label></value>
            <value><fullName>Processing</fullName><default>false</default><label>Processing</label></value>
            <value><fullName>Processed</fullName><default>false</default><label>Processed</label></value>
            <value><fullName>Failed</fullName><default>false</default><label>Failed</label></value>
            <value><fullName>Poisoned</fullName><default>false</default><label>Poisoned</label></value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
