<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Status__c</fullName>
    <description>Normalized framework status for this transport message as it moves through receive, processing, draft, send, suppression, or failure states.</description>
    <inlineHelpText>Shows the current high-level handling state for the message, independent of any provider-specific status text.</inlineHelpText>
    <label>Status</label>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>Received</fullName>
                <default>false</default>
                <label>Received</label>
            </value>
            <value>
                <fullName>Processing</fullName>
                <default>true</default>
                <label>Processing</label>
            </value>
            <value>
                <fullName>Drafted</fullName>
                <default>false</default>
                <label>Drafted</label>
            </value>
            <value>
                <fullName>Sent</fullName>
                <default>false</default>
                <label>Sent</label>
            </value>
            <value>
                <fullName>Delivered</fullName>
                <default>false</default>
                <label>Delivered</label>
            </value>
            <value>
                <fullName>Read</fullName>
                <default>false</default>
                <label>Read</label>
            </value>
            <value>
                <fullName>Suppressed</fullName>
                <default>false</default>
                <label>Suppressed</label>
            </value>
            <value>
                <fullName>Failed</fullName>
                <default>false</default>
                <label>Failed</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
