<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ErrorHandlingMode__c</fullName>
    <description>Controls whether the pipeline stops at the first failed step or continues to the next step.</description>
    <inlineHelpText>Choose Fail Fast to stop on the first error. Choose Continue On Error to skip failed steps and keep running.</inlineHelpText>
    <label>Error Handling Mode</label>
    <required>false</required>
    <trackHistory>true</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Picklist</type>
    <valueSet>
        <restricted>true</restricted>
        <valueSetDefinition>
            <sorted>false</sorted>
            <value>
                <fullName>FailFast</fullName>
                <default>true</default>
                <label>Fail Fast</label>
            </value>
            <value>
                <fullName>ContinueOnError</fullName>
                <default>false</default>
                <label>Continue On Error</label>
            </value>
        </valueSetDefinition>
    </valueSet>
</CustomField>
