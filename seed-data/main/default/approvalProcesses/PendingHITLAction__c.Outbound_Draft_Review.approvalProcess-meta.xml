<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>true</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>allInternalUsers</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>ArtifactType__c</field>
        <field>ApprovalCategory__c</field>
        <field>ApprovalRouteDeveloperName__c</field>
        <field>ApprovalProcessDeveloperName__c</field>
        <field>ApproverRoutingType__c</field>
        <field>ApproverRoutingKey__c</field>
        <field>InteractionChannel__c</field>
        <field>ToolName__c</field>
        <field>ReviewedPayloadJson__c</field>
        <field>ConfirmationPrompt__c</field>
        <field>HITLType__c</field>
        <field>RequestingUser__c</field>
        <field>RequestedAt__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>true</allowDelegate>
        <assignedApprover>
            <approver>
                <name>Outbound_Draft_Review_Queue</name>
                <type>queue</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Outbound Draft Review Step</label>
        <name>Outbound_Draft_Review_Step</name>
    </approvalStep>
    <description>Approval process for Review Before Send artifacts so outbound drafts can be reviewed independently from tool approvals.</description>
    <enableMobileDeviceAccess>true</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>PendingHITLAction__c.Status__c</field>
            <operation>equals</operation>
            <value>Pending</value>
        </criteriaItems>
        <criteriaItems>
            <field>PendingHITLAction__c.ApprovalCategory__c</field>
            <operation>equals</operation>
            <value>Outbound Draft Review</value>
        </criteriaItems>
        <criteriaItems>
            <field>PendingHITLAction__c.ApprovalProcessDeveloperName__c</field>
            <operation>equals</operation>
            <value>Outbound_Draft_Review</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>HITL_Status_Approved</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>HITL_Status_Rejected</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <label>Outbound Draft Review</label>
    <processOrder>2</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
